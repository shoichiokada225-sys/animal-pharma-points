<div class="mb-6">
  <a href="/customers" class="text-sm text-blue-600 hover:underline">&larr; 顧客一覧に戻る</a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
  <div class="lg:col-span-2">
    <div class="bg-white rounded-xl border border-gray-200 p-6">
      <div class="flex items-start justify-between mb-4">
        <div>
          <h1 class="text-2xl font-bold text-gray-800"><%= customer.customer_name %></h1>
          <p class="text-sm text-gray-500 font-mono"><%= customer.customer_id %></p>
        </div>
        <% const tierLabel = { general: '一般', silver: 'シルバー', gold: 'ゴールド' }[customer.tier] || '一般'; %>
        <% const tierBg = customer.tier === 'gold' ? 'bg-yellow-100 text-yellow-700' : customer.tier === 'silver' ? 'bg-gray-100 text-gray-600' : 'bg-blue-50 text-blue-600'; %>
        <span class="px-3 py-1 rounded-full text-sm font-semibold <%= tierBg %>"><%= tierLabel %></span>
      </div>
      <div class="grid grid-cols-2 gap-4 text-sm">
        <div><span class="text-gray-500">メール:</span> <span class="text-gray-800"><%= customer.email || '未登録' %></span></div>
        <div><span class="text-gray-500">登録日:</span> <span class="text-gray-800"><%= customer.created_at ? customer.created_at.slice(0, 10) : '-' %></span></div>
      </div>
    </div>
  </div>
  <div class="bg-gradient-to-br from-blue-500 to-blue-700 rounded-xl p-6 text-white">
    <div class="text-sm opacity-90 mb-2">現在の保有ポイント</div>
    <div class="text-4xl font-bold"><%= balance.toLocaleString() %><span class="text-lg ml-1 opacity-90">pt</span></div>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <h3 class="text-sm font-semibold text-gray-700 mb-3">ポイント利用</h3>
    <form method="POST" action="/redeem" onsubmit="return confirm('ポイントを利用しますか？')">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="customer_id" value="<%= customer.customer_id %>">
      <input type="hidden" name="redirect" value="/customers/<%= customer.customer_id %>">
      <div class="flex gap-2">
        <input type="number" name="points" min="1" max="<%= balance %>" required placeholder="ポイント数"
          class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        <input type="text" name="note" placeholder="備考(任意)"
          class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        <button type="submit" class="px-4 py-2 bg-green-600 text-white text-sm rounded-lg hover:bg-green-700">利用</button>
      </div>
    </form>
  </div>
  <div class="bg-white rounded-xl border border-gray-200 p-5">
    <h3 class="text-sm font-semibold text-gray-700 mb-3">取引取消</h3>
    <form method="POST" action="/cancel" onsubmit="return confirm('この取引を取り消しますか？')">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="redirect" value="/customers/<%= customer.customer_id %>">
      <div class="flex gap-2">
        <input type="text" name="transaction_id" required placeholder="取引ID (例: T20260403-001)"
          class="flex-1 px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
        <button type="submit" class="px-4 py-2 bg-red-600 text-white text-sm rounded-lg hover:bg-red-700">取消</button>
      </div>
    </form>
  </div>
</div>

<h2 class="text-lg font-semibold text-gray-800 mb-3">ポイント履歴</h2>
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden mb-4">
  <table class="w-full">
    <thead>
      <tr class="border-b border-gray-100 bg-gray-50">
        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500">日時</th>
        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500">種別</th>
        <th class="px-4 py-2.5 text-right text-xs font-semibold text-gray-500">ポイント</th>
        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500">取引ID</th>
        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500">備考</th>
        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500">有効期限</th>
      </tr>
    </thead>
    <tbody>
      <% if (history.length === 0) { %>
      <tr><td colspan="6" class="px-4 py-6 text-center text-sm text-gray-400">履歴がありません</td></tr>
      <% } else { %>
      <% for (const h of history) { %>
      <% const typeLabel = { EARN: '付与', CANCEL: '取消', EXPIRE: '失効', REDEEM: '利用' }[h.type] || h.type; %>
      <% const typeClass = h.type === 'EARN' ? 'bg-green-50 text-green-700' : h.type === 'CANCEL' ? 'bg-red-50 text-red-700' : h.type === 'REDEEM' ? 'bg-orange-50 text-orange-700' : 'bg-gray-50 text-gray-700'; %>
      <% const ptClass = h.points >= 0 ? 'text-green-600' : 'text-red-600'; %>
      <tr class="border-b border-gray-50 hover:bg-gray-50">
        <td class="px-4 py-2.5 text-xs text-gray-500"><%= (h.created_at || '').slice(0, 16).replace('T', ' ') %></td>
        <td class="px-4 py-2.5"><span class="px-2 py-0.5 rounded text-xs font-medium <%= typeClass %>"><%= typeLabel %></span></td>
        <td class="px-4 py-2.5 text-sm text-right font-semibold <%= ptClass %>"><%= h.points >= 0 ? '+' : '' %><%= h.points.toLocaleString() %></td>
        <td class="px-4 py-2.5 text-xs text-gray-500 font-mono"><%= h.transaction_id || '-' %></td>
        <td class="px-4 py-2.5 text-xs text-gray-500"><%= h.note || '' %></td>
        <td class="px-4 py-2.5 text-xs text-gray-400"><%= h.valid_until || '-' %></td>
      </tr>
      <% } %>
      <% } %>
    </tbody>
  </table>
</div>

<% if (totalPages > 1) { %>
<div class="flex justify-center gap-2">
  <% for (let p = 1; p <= totalPages; p++) { %>
  <a href="/customers/<%= customer.customer_id %>?page=<%= p %>"
    class="px-3 py-1 rounded text-sm <%= p === page ? 'bg-blue-600 text-white' : 'bg-white border border-gray-300 text-gray-600 hover:bg-gray-50' %>"><%= p %></a>
  <% } %>
</div>
<% } %>
