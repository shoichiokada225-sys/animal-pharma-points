<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>ログイン - ポイント管理</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center">
  <div class="w-full max-w-sm">
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
      <h1 class="text-xl font-bold text-gray-800 text-center mb-1">ポイント管理システム</h1>
      <p class="text-sm text-gray-500 text-center mb-6">動物医薬品卸 社内ダッシュボード</p>

      <% if (error) { %>
        <div class="mb-4 p-3 bg-red-50 border border-red-200 text-red-700 rounded-lg text-sm"><%= error %></div>
      <% } %>

      <form method="POST" action="/login">
        <label class="block text-sm font-medium text-gray-700 mb-1">パスワード</label>
        <input
          type="password"
          name="password"
          required
          autofocus
          class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent mb-4"
          placeholder="パスワードを入力"
        >
        <button
          type="submit"
          class="w-full bg-blue-600 text-white py-2 rounded-lg font-medium hover:bg-blue-700 transition"
        >ログイン</button>
      </form>
    </div>
  </div>
</body>
</html>
