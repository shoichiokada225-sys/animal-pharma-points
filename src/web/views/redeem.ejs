<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-800">ポイント利用</h1>
</div>

<div class="max-w-xl">
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <form method="POST" action="/redeem" onsubmit="return confirm('ポイントを利用しますか？')">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">顧客</label>
        <select name="customer_id" required class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
          <option value="">選択してください</option>
          <% for (const c of customers) { %>
          <option value="<%= c.customer_id %>"><%= c.customer_id %> - <%= c.customer_name %> (<%= c.balance.toLocaleString() %>pt)</option>
          <% } %>
        </select>
      </div>

      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-1">利用ポイント数</label>
        <input type="number" name="points" min="1" required
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
          placeholder="例: 100">
      </div>

      <div class="mb-6">
        <label class="block text-sm font-medium text-gray-700 mb-1">備考（任意）</label>
        <input type="text" name="note"
          class="w-full px-3 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
          placeholder="例: 商品A交換">
      </div>

      <button type="submit" class="w-full px-4 py-2 bg-green-600 text-white rounded-lg font-medium hover:bg-green-700 transition">
        ポイントを利用する
      </button>
    </form>
  </div>
</div>
