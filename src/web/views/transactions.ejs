<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-800">取引管理</h1>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">月次バッチ一括実行</h2>
    <p class="text-xs text-gray-500 mb-3">取引取込 → 失効処理 → ランク更新 → Excel/HTML出力 を一括実行します。</p>
    <form method="POST" action="/transactions/monthly" enctype="multipart/form-data" onsubmit="return confirm('月次バッチを実行しますか？')">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="file" name="file" accept=".xlsx" required
        class="block w-full text-sm text-gray-500 mb-3 file:mr-2 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
      <button type="submit" class="w-full px-4 py-2 bg-blue-600 text-white text-sm rounded-lg font-medium hover:bg-blue-700">実行</button>
    </form>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">取引Excel取込のみ</h2>
    <p class="text-xs text-gray-500 mb-3">ポイント付与のみ実行（エクスポートなし）。</p>
    <form method="POST" action="/transactions/import" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="file" name="file" accept=".xlsx" required
        class="block w-full text-sm text-gray-500 mb-3 file:mr-2 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-gray-50 file:text-gray-700 hover:file:bg-gray-100">
      <button type="submit" class="w-full px-4 py-2 bg-gray-600 text-white text-sm rounded-lg font-medium hover:bg-gray-700">取込</button>
    </form>
  </div>

  <div class="bg-white rounded-xl border border-gray-200 p-6">
    <h2 class="text-sm font-semibold text-gray-700 mb-3">顧客マスタ取込</h2>
    <p class="text-xs text-gray-500 mb-3">customers.xlsx をアップロードして顧客情報を更新。</p>
    <form method="POST" action="/transactions/import-customers" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="file" name="file" accept=".xlsx" required
        class="block w-full text-sm text-gray-500 mb-3 file:mr-2 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-sm file:font-medium file:bg-gray-50 file:text-gray-700 hover:file:bg-gray-100">
      <button type="submit" class="w-full px-4 py-2 bg-gray-600 text-white text-sm rounded-lg font-medium hover:bg-gray-700">取込</button>
    </form>
  </div>
</div>

<h2 class="text-lg font-semibold text-gray-800 mb-3">直近の取引（20件）</h2>
<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <table class="w-full">
    <thead>
      <tr class="border-b border-gray-100 bg-gray-50">
        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500">取引ID</th>
        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500">顧客ID</th>
        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500">取引日</th>
        <th class="px-4 py-2.5 text-right text-xs font-semibold text-gray-500">金額</th>
        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500">分類</th>
        <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500">取込日時</th>
      </tr>
    </thead>
    <tbody>
      <% if (recentTx.length === 0) { %>
      <tr><td colspan="6" class="px-4 py-6 text-center text-sm text-gray-400">取引データがありません</td></tr>
      <% } else { %>
      <% for (const t of recentTx) { %>
      <tr class="border-b border-gray-50 hover:bg-gray-50">
        <td class="px-4 py-2.5 text-sm font-mono"><%= t.transaction_id %></td>
        <td class="px-4 py-2.5 text-sm"><a href="/customers/<%= t.customer_id %>" class="text-blue-600 hover:underline"><%= t.customer_id %></a></td>
        <td class="px-4 py-2.5 text-sm"><%= t.transaction_date %></td>
        <td class="px-4 py-2.5 text-sm text-right">&yen;<%= t.amount.toLocaleString() %></td>
        <td class="px-4 py-2.5 text-sm text-gray-500"><%= t.category || '-' %></td>
        <td class="px-4 py-2.5 text-xs text-gray-400"><%= (t.imported_at || '').slice(0, 16).replace('T', ' ') %></td>
      </tr>
      <% } %>
      <% } %>
    </tbody>
  </table>
</div>
