<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-800">顧客一覧</h1>
  <a href="/transactions" class="px-4 py-2 bg-blue-600 text-white text-sm rounded-lg hover:bg-blue-700">顧客マスタ取込</a>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <table class="w-full">
    <thead>
      <tr class="border-b border-gray-100 bg-gray-50">
        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500">顧客ID</th>
        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500">顧客名</th>
        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500">メール</th>
        <th class="px-4 py-3 text-left text-xs font-semibold text-gray-500">ランク</th>
        <th class="px-4 py-3 text-right text-xs font-semibold text-gray-500">残高</th>
        <th class="px-4 py-3 text-center text-xs font-semibold text-gray-500">操作</th>
      </tr>
    </thead>
    <tbody>
      <% for (const c of customers) { %>
      <% const tierLabel = { general: '一般', silver: 'シルバー', gold: 'ゴールド' }[c.tier] || '一般'; %>
      <% const tierClass = c.tier === 'gold' ? 'text-yellow-600 font-medium' : c.tier === 'silver' ? 'text-gray-500 font-medium' : 'text-gray-400'; %>
      <tr class="border-b border-gray-50 hover:bg-gray-50">
        <td class="px-4 py-3 text-sm font-mono"><%= c.customer_id %></td>
        <td class="px-4 py-3 text-sm font-medium"><a href="/customers/<%= c.customer_id %>" class="text-blue-600 hover:underline"><%= c.customer_name %></a></td>
        <td class="px-4 py-3 text-sm text-gray-500"><%= c.email || '-' %></td>
        <td class="px-4 py-3 text-sm <%= tierClass %>"><%= tierLabel %></td>
        <td class="px-4 py-3 text-sm text-right font-semibold"><%= c.balance.toLocaleString() %> pt</td>
        <td class="px-4 py-3 text-center"><a href="/customers/<%= c.customer_id %>" class="text-blue-600 text-sm hover:underline">詳細</a></td>
      </tr>
      <% } %>
    </tbody>
  </table>
</div>
