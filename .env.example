# Neon PostgreSQL 接続文字列
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Webダッシュボード設定
# パスワードハッシュは以下で生成:
#   node -e "import('bcrypt').then(b=>b.default.hash('your-password',10).then(console.log))"
APP_PASSWORD_HASH=$2b$10$xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SESSION_SECRET=change-this-to-a-random-string
PORT=4000
